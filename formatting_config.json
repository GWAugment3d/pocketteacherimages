{
  "version": "1.0.0",
  "description": "PocketTeacher content formatting and semantic section styling config. Controls lesson content presentation only. Does not override core UI components.",

  "scope": {
    "controls": [
      "lesson content typography",
      "section header styling",
      "content spacing",
      "semantic content containers",
      "case study presentation",
      "knowledge check presentation",
      "final quiz presentation",
      "progressive reveal flow rules"
    ],
    "doesNotControl": [
      "multiple choice buttons",
      "answer tiles",
      "chat input bar",
      "navigation UI",
      "menu buttons",
      "send button",
      "footer UI",
      "existing app shell components"
    ],
    "uiComponentsOverrideConfig": true
  },

  "flowRules": {
    "mobileFirst": true,
    "forceProgressiveReveal": true,
    "maxSectionsPerResponse": 1,
    "maxBulletsPerSection": 3,
    "maxParagraphsPerSection": 2,
    "maxLinesPerParagraph": 3,
    "avoidTextbookStacking": true,
    "preferChatFeedRhythm": true
  },

  "layout": {
    "maxWidth": 420,
    "horizontalPadding": 16,
    "verticalPadding": 10,
    "sectionGap": 16,
    "elementGap": 8,
    "cardPadding": 12,
    "cardRadius": 12
  },

  "typography": {
    "title": {
      "fontFamily": "Permanent Marker",
      "fontSize": 26,
      "fontWeight": 600,
      "lineHeight": 1.15,
      "color": "#6A0DAD",
      "marginBottom": 8
    },
    "sectionHeader": {
      "fontFamily": "Inter",
      "fontSize": 17,
      "fontWeight": 700,
      "lineHeight": 1.2,
      "color": "#1f2937",
      "marginTop": 14,
      "marginBottom": 6
    },
    "sectionHeaderAccent": {
      "fontFamily": "Permanent Marker",
      "fontSize": 16,
      "fontWeight": 600,
      "lineHeight": 1.15
    },
    "body": {
      "fontFamily": "Inter",
      "fontSize": 15,
      "fontWeight": 400,
      "lineHeight": 1.45,
      "color": "#1f2937"
    },
    "bodyEmphasis": {
      "fontWeight": 700,
      "color": "#0f172a"
    },
    "microLabel": {
      "fontFamily": "Inter",
      "fontSize": 11,
      "fontWeight": 700,
      "lineHeight": 1.1,
      "letterSpacing": 0.08,
      "textTransform": "uppercase",
      "color": "#6b7280"
    }
  },

  "colors": {
    "backgroundPaper": "#f5f5f4",
    "textPrimary": "#1f2937",
    "textSecondary": "#6b7280",
    "teacherPurple": "#6A0DAD",
    "ao1Amber": "#D97706",
    "ao2Blue": "#2563EB",
    "ao3Green": "#16A34A",
    "dangerRed": "#DC2626",
    "frostedWhite": "rgba(255,255,255,0.68)",
    "checkBlueBg": "#EFF6FF",
    "checkBlueBorder": "#2563EB",
    "finalGreenBg": "#ECFDF5",
    "finalGreenBorder": "#16A34A",
    "caseStudyPaper": "#f8f5ef"
  },

  "bullets": {
    "style": "icon + bold term + colon + short explanation",
    "iconSize": 18,
    "itemGap": 6,
    "termWeight": 700,
    "allowEmojiIcons": true,
    "maxItems": 3
  },

  "containers": {
    "plain": {
      "background": "transparent",
      "border": "none",
      "shadow": "none",
      "padding": 0,
      "radius": 0
    },
    "frostedCard": {
      "background": "rgba(255,255,255,0.68)",
      "backdropBlur": 6,
      "border": "1px solid rgba(255,255,255,0.35)",
      "shadow": {
        "color": "rgba(0,0,0,0.08)",
        "blur": 12,
        "y": 4
      },
      "padding": 12,
      "radius": 12
    },
    "checkCard": {
      "background": "#EFF6FF",
      "borderLeft": "4px solid #2563EB",
      "shadow": {
        "color": "rgba(37,99,235,0.08)",
        "blur": 10,
        "y": 3
      },
      "padding": 12,
      "radius": 12
    },
    "finalCard": {
      "background": "#ECFDF5",
      "borderLeft": "4px solid #16A34A",
      "shadow": {
        "color": "rgba(22,163,74,0.08)",
        "blur": 10,
        "y": 3
      },
      "padding": 12,
      "radius": 12
    },
    "tornPaper": {
      "background": "#f8f5ef",
      "border": "1px solid rgba(0,0,0,0.04)",
      "shadow": {
        "color": "rgba(0,0,0,0.10)",
        "blur": 14,
        "y": 6
      },
      "padding": 14,
      "radius": 12,
      "texture": "paper",
      "edgeStyle": "torn"
    }
  },

  "sectionTypes": {
    "topicTitle": {
      "container": "plain",
      "headerStyle": "title"
    },
    "contentIntro": {
      "container": "plain",
      "headerStyle": "sectionHeader"
    },
    "keyContent": {
      "container": "plain",
      "headerStyle": "sectionHeaderAccent",
      "headerColor": "#D97706"
    },
    "benefits": {
      "container": "plain",
      "headerStyle": "sectionHeaderAccent",
      "headerColor": "#16A34A"
    },
    "drawbacks": {
      "container": "plain",
      "headerStyle": "sectionHeaderAccent",
      "headerColor": "#DC2626"
    },
    "businessImpact": {
      "container": "frostedCard",
      "headerStyle": "sectionHeaderAccent",
      "headerColor": "#D97706"
    },
    "realExample": {
      "container": "frostedCard",
      "headerStyle": "sectionHeaderAccent",
      "headerColor": "#D97706"
    },
    "caseStudy": {
      "container": "tornPaper",
      "headerStyle": "sectionHeader",
      "headerColor": "#1f2937",
      "titleStyle": "sectionHeader",
      "questionStyle": "bodyEmphasis"
    },
    "knowledgeCheck": {
      "container": "checkCard",
      "headerStyle": "sectionHeaderAccent",
      "headerColor": "#2563EB",
      "microLabel": "CHECK"
    },
    "finalCheck": {
      "container": "finalCard",
      "headerStyle": "sectionHeaderAccent",
      "headerColor": "#16A34A",
      "microLabel": "TEST"
    }
  },

  "caseStudyRules": {
    "useTornPaperContainer": true,
    "keepSeparateFromNormalLessonFlow": true,
    "showAsSpecialArtifact": true,
    "maxVisibleParagraphsBeforeQuestion": 3,
    "questionMustBeVisuallySeparated": true
  },

  "renderRules": {
    "maxHeadingLevels": 3,
    "noHandwrittenBelowTitleExceptSectionAccents": false,
    "cardsOnlyForSemanticSections": true,
    "doNotInventNewVisualSystems": true,
    "fallbackToNearestExistingStyle": true,
    "keepChecksVisuallyDistinct": true,
    "preserveWhitespaceDiscipline": true
  }
}
